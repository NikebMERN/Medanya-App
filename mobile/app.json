{
  "expo": {
    "name": "Medanya",
    "slug": "medanya",
    "version": "1.0.0",
    "scheme": "medanya",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f2f6ff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medanya.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "deploymentTarget": "15.1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.12212015536-iabo63q7ah6231qs7nthmhu7sduher66"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.medanya.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f2f6ff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "@react-native-firebase/app",
      [
        "react-native-fbsdk-next",
        {
          "appID": "3255354417977637",
          "clientToken": "2db00a3dda965efdfce1abf02afa31c0",
          "displayName": "Medanya",
          "scheme": "fb3255354417977637"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Medanya to access your camera to record videos.",
          "recordAudioAndroid": true
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you upload a profile picture and share images or videos in chat."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow access to save photos to your photo library.",
          "savePhotosPermission": "Allow access to save photos to your photo library."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#f2f6ff",
          "resizeMode": "contain",
          "imageWidth": 280
        }
      ],
      "expo-video",
      [
        "./plugins/withGoogleMobileAds.js",
        {
          "androidAppId": "ca-app-pub-1717403054658770~9594579402",
          "iosAppId": "ca-app-pub-1717403054658770~7234011500"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "This app uses tracking to show you relevant ads and improve your experience."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "extraMavenRepos": ["https://cdn.veriff.me/android/"]
          }
        }
      ],
      "expo-audio",
      "./plugins/withVeriffMaven.js"
    ],
    "extra": {
      "eas": {
        "projectId": "4b563fc0-e903-4104-bac4-548c48f8ef2c"
      }
    },
    "owner": "nikeb"
  }
}