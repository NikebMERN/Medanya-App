# Backend base URL — do NOT include /api (the app adds it).
# Run `npm run update-api-url` or `npm start` to auto-set this to your machine's IP (for device/emulator).
# Example: http://192.168.0.101:4001  (not http://localhost:4001/api)
EXPO_PUBLIC_API_URL=http://localhost:4001
EXPO_PUBLIC_SOCKET_URL=

# Cloudinary (unsigned upload): app uploads image -> gets URL -> sends URL to backend.
# Where to get these (free account at https://cloudinary.com):
# 1. Cloud name: Dashboard home or Settings > Product environment credentials > Cloud name
# 2. Upload preset: Settings > Upload > Upload presets > Add upload preset
#    - Set "Signing Mode" to "Unsigned" (required for app uploads)
#    - Save and use the "Preset name" (e.g. medanya_unsigned)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Firebase (required for Google/Facebook sign-in). Leave empty = app loads but social sign-in disabled.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# For Expo Go (proxy): Web OAuth client with redirect https://auth.expo.io/@YOUR_USERNAME/medanya
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
# For Dev Build / Production: from GoogleService-Info.plist and google-services.json
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Facebook Sign-In (from Facebook Developers app dashboard)
EXPO_PUBLIC_FACEBOOK_APP_ID=917378897864325

# Agora (livestream). Required for host→viewer video. Get from https://console.agora.io
# EXPO_PUBLIC_AGORA_APP_ID=your_agora_app_id

# --- Backend only (do NOT use in mobile app): FIREBASE_PROJECT_ID, FIREBASE_CLIENT_EMAIL, FIREBASE_PRIVATE_KEY ---

# Web app homepage — OAuth redirect on web. Add to Google, Facebook, Firebase Authorized domains.
# EXPO_PUBLIC_WEB_APP_URL=http://localhost:19006
# EXPO_PUBLIC_WEB_APP_URL=https://medanya.app
# If unset, app uses FIREBASE_AUTH_DOMAIN to build it, or Expo auth proxy.
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=

# Stripe (in-app card payment for marketplace orders and wallet recharge). Get from https://dashboard.stripe.com/apikeys
# Use the Publishable key (pk_test_... or pk_live_...).
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AdMob — Get from https://admob.google.com
# App IDs go in app.json plugins["react-native-google-mobile-ads"]
# In __DEV__ we use Google test IDs; in production use your real ad unit IDs.
# EXPO_PUBLIC_ADMOB_APP_ID_IOS=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
# EXPO_PUBLIC_ADMOB_APP_ID_ANDROID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
# Rewarded (Earn Coins)
# EXPO_PUBLIC_ADMOB_REWARDED_AD_UNIT_ID=ca-app-pub-XXXXXXXXXXXXXXXX/YYYYYYYYYY
# EXPO_PUBLIC_ADMOB_REWARDED_ID_IOS=
# EXPO_PUBLIC_ADMOB_REWARDED_ID_ANDROID=
# Banner (optional)
# EXPO_PUBLIC_ADMOB_BANNER_ID=
# EXPO_PUBLIC_ADMOB_BANNER_ID_IOS=
# EXPO_PUBLIC_ADMOB_BANNER_ID_ANDROID=
# Interstitial (optional)
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_IOS=
# EXPO_PUBLIC_ADMOB_INTERSTITIAL_ID_ANDROID=
