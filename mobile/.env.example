# Backend base URL — do NOT include /api (the app adds it). Use your PC IP when testing on device.
# Example: http://192.168.0.101:4001  (not http://localhost:4001/api)
EXPO_PUBLIC_API_URL=http://localhost:4001
# EXPO_PUBLIC_SOCKET_URL=

# Cloudinary (unsigned upload): app uploads image -> gets URL -> sends URL to backend.
# Where to get these (free account at https://cloudinary.com):
# 1. Cloud name: Dashboard home or Settings > Product environment credentials > Cloud name
# 2. Upload preset: Settings > Upload > Upload presets > Add upload preset
#    - Set "Signing Mode" to "Unsigned" (required for app uploads)
#    - Save and use the "Preset name" (e.g. medanya_unsigned)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset_name

# Firebase (required for Google/Facebook sign-in)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# Google Sign-In (Web client ID from Firebase Console > Auth > Google)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxx.apps.googleusercontent.com

# Facebook Sign-In (from Facebook Developers app dashboard)
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Optional: OAuth redirect URI. If set, used for Google/Facebook (e.g. Firebase handler).
# Example: https://medanya-project.firebaseapp.com/__/auth/handler
# If unset, app uses FIREBASE_AUTH_DOMAIN to build it, or Expo auth proxy.
# EXPO_PUBLIC_OAUTH_REDIRECT_URI=
