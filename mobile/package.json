{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "update-api-url": "node scripts/update-api-url.js",
    "start": "node scripts/update-api-url.js && expo start",
    "start:clean": "node scripts/update-api-url.js && expo start --clear",
    "clean": "node -e \"const fs=require('fs');const path=require('path');const rm=(p)=>{try{fs.existsSync(p)&&fs.rmSync(p,{recursive:true});}catch(e){}};rm(path.join(process.cwd(),'.expo'));rm(path.join(process.cwd(),'node_modules','.cache'));console.log('Cache cleared.');\"",
    "start:online": "expo start",
    "android": "expo start --offline --android",
    "ios": "expo start --offline --ios",
    "web": "expo start --offline --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@sumsub/react-native-mobilesdk-module": "^1.40.0",
    "@tanstack/react-query": "^5.90.20",
    "@veriff/react-native-sdk": "^4.0.0",
    "axios": "^1.13.4",
    "expo": "~54.0.33",
    "expo-asset": "^12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "^18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "~15.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "^8.0.11",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^11.6.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.11"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "sharp": "^0.34.5"
  }
}
