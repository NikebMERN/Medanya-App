{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "update-api-url": "node scripts/update-api-url.js",
    "start": "node scripts/update-api-url.js && expo start",
    "start:clean": "node scripts/update-api-url.js && expo start --clear",
    "clean": "node -e \"const fs=require('fs');const path=require('path');const rm=(p)=>{try{fs.existsSync(p)&&fs.rmSync(p,{recursive:true});}catch(e){}};rm(path.join(process.cwd(),'.expo'));rm(path.join(process.cwd(),'node_modules','.cache'));console.log('Cache cleared.');\"",
    "start:online": "expo start",
    "android": "expo start --offline --android",
    "ios": "expo start --offline --ios",
    "web": "node scripts/update-api-url.js && expo start --web",
    "web:clean": "node scripts/update-api-url.js && expo start --clear --web",
    "postinstall": "patch-package",
    "prebuild": "npx expo prebuild",
    "build:dev:ios": "npx eas-cli build --profile development --platform ios",
    "build:dev:android": "npx eas-cli build --profile development --platform android",
    "build:dev": "npx eas-cli build --profile development --platform all",
    "start:dev-client:tunnel": "node scripts/update-api-url.js && npx expo start --tunnel --dev-client",
    "start:dev-client:tunnel:clean": "node scripts/update-api-url.js && expo start --clear --tunnel --dev-client",
    "start:dev-client": "node scripts/update-api-url.js && npx expo start --dev-client",
    "start:dev-client:lan": "node scripts/update-api-url.js && npx expo start --lan --dev-client",
    "start:dev-client:clean": "node scripts/update-api-url.js && expo start --clear --dev-client"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/crashlytics": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@shopify/react-native-skia": "2.2.12",
    "@stripe/stripe-react-native": "^0.50.3",
    "@tanstack/react-query": "^5.90.20",
    "@veriff/react-native-sdk": "^4.0.0",
    "agora-rtc-sdk-ng": "^4.24.2",
    "axios": "^1.13.4",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-asset": "^12.0.12",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.10",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "^18.0.13",
    "expo-contacts": "~15.0.11",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "^8.0.11",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "^31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "firebase": "^11.6.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-agora": "^4.5.3",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.3.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "socket.io-client": "^4.8.3",
    "victory-native": "^41.20.2",
    "zustand": "^5.0.11"
  },
  "private": true,
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "patch-package": "^8.0.1",
    "sharp": "^0.34.5"
  }
}
