# ============================================================
# Sumsub KYC Provider - Example .env
# Copy to .env and fill in your Sumsub credentials
# ============================================================

# KYC Provider: use Sumsub (not Veriff)
KYC_PROVIDER=sumsub

# Sumsub API credentials (from Sumsub Dashboard → API)
SUMSUB_APP_TOKEN=your_app_token_here
SUMSUB_SECRET_KEY=your_secret_key_here

# Webhook secret for signature verification
# Create a webhook in Sumsub Dashboard and copy the secret
# Webhook URL: https://your-api-domain.com/api/webhooks/sumsub/applicantReviewed
SUMSUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional: override base URL (default: https://api.sumsub.com)
# SUMSUB_BASE_URL=https://api.sumsub.com

# Optional: verification level name (default: basic-kyc-level)
# Create levels in Sumsub Dashboard → Verification flow
# SUMSUB_LEVEL_NAME=basic-kyc-level
