# Scam AI (optional - defaults to rules-only, zero cost)
# AI_PROVIDER=rules
# AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# SCAM_AI_SYNC_TIMEOUT_MS=1500
# SCAM_AI_DEEP_TIMEOUT_MS=5000
# SCAM_AI_HASH_SALT=medanya-scam-ai-salt-v1

# Scam ML (Python inference service - started automatically with npm start)
# ML_INFERENCE_URL=http://127.0.0.1:8000
# ML_INFERENCE_PORT=8000
# ML_INFERENCE_TIMEOUT_MS=300
# ML_START_INFERENCE=true
# ML_MIN_LABELS_FOR_TRAINING=200
# ML_TRAIN_SCRIPT=python ml/train.py
