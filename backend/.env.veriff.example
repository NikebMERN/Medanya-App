# ============================================================
# Veriff KYC Provider - Example .env
# Copy to .env and fill in your Veriff credentials
# ============================================================

# KYC Provider: use Veriff (not Sumsub)
KYC_PROVIDER=veriff

# Veriff API credentials (from Veriff Customer Portal → API Keys)
VERIFF_API_KEY=your_api_key_here
VERIFF_SHARED_SECRET=your_shared_secret_here

# PUBLIC_WEBHOOK_BASE_URL: Public HTTPS domain Veriff can reach (NOT localhost)
# Use ngrok for local dev: ngrok http 4001 → set to https://xxx.ngrok.io
PUBLIC_WEBHOOK_BASE_URL=https://your-ngrok-or-prod-domain.com

# Webhook URLs (configure in Veriff Customer Portal):
# Decision: <PUBLIC_WEBHOOK_BASE_URL>/api/webhooks/veriff/decision
# Events:   <PUBLIC_WEBHOOK_BASE_URL>/api/webhooks/veriff/events

# HMAC: Uses VERIFF_SHARED_SECRET (raw body is signed). No VERIFF_WEBHOOK_SECRET.

# Optional: callback URL for redirect after flow
# VERIFF_CALLBACK_URL=<PUBLIC_WEBHOOK_BASE_URL>/api/veriff/callback
# VERIFF_CALLBACK_REDIRECT_URL=medanya://veriff/done

# Optional: override base URL (default: https://stationapi.veriff.com)
# VERIFF_BASE_URL=https://stationapi.veriff.com
